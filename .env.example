# News API Configuration
# Get your free API key from: https://newsapi.org/
# Sign up, copy your API key, and set it below

NEWS_API_KEY=your_api_key_here

# IMPORTANT: 
# 1. Create a .env file (not committed to git)
# 2. Copy this template and add your actual API key
# 3. Install python-dotenv: pip install python-dotenv
# 4. The app will use your API key to fetch real-time news

# Example with a real key:
# NEWS_API_KEY=abc123def456ghi789jkl
